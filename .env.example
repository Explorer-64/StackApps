# Frontend build-time vars (values from DATABUTTON_EXTENSIONS in GCP Secret Manager)
VITE_FIREBASE_API_KEY=
# Use your custom domain in production (e.g. stackapps.app) so Google sign-in says "continue to stackapps.app", not *.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend — Cloud Run injects these from GCP Secret Manager automatically
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_STORAGE_BUCKET=
GOOGLEAI_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# Local dev only
PYTHON_BACKEND_URL=http://localhost:8001
PYTHON_BACKEND_PORT=8001
